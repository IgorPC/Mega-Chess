# ==============================================================================
# Mega Chess Online — API local development environment variables
#
# Copy this file to `.env` inside apps/api/, fill in the values below, then
# run the API locally with `npm run start:dev` (or let the local
# docker-compose.yml mount it in). NestJS's ConfigModule loads this file
# automatically — no extra setup required.
#
# This file targets LOCAL DEVELOPMENT. For production values, see the
# `.env.example` file in the project root (used by docker-compose.prod.yml).
# ==============================================================================

# ------------------------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------------------------

# REQUIRED. Full connection string.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# Matches the `db` service in the root docker-compose.yml (user "chess",
# password "chess_secret", database "megachess", exposed on localhost:5432).
DATABASE_URL=postgresql://chess:chess_secret@localhost:5432/megachess

# ------------------------------------------------------------------------------
# Cache / sessions (Redis)
# ------------------------------------------------------------------------------

# Redis connection string. Defaults to redis://localhost:6379 if omitted —
# matches the `redis` service in the root docker-compose.yml.
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------------------------
# Authentication (JWT secrets)
# ------------------------------------------------------------------------------

# REQUIRED. Any non-empty string works locally; use a long random value in
# any environment other machines can reach.
JWT_SECRET=dev_jwt_secret_change_me

# REQUIRED. Secret reserved for refresh-token signing.
JWT_REFRESH_SECRET=dev_refresh_secret_change_me

# REQUIRED. Secret used to sign admin-panel JWTs.
ADMIN_JWT_SECRET=dev_admin_secret_change_me

# ------------------------------------------------------------------------------
# Server
# ------------------------------------------------------------------------------

# Port the NestJS server listens on.
PORT=3000

# Controls TypeORM's `synchronize` (auto schema sync — only safe outside
# production) and SQL query logging.
# Options: development | production | test
NODE_ENV=development

# Comma-separated list of origins allowed by CORS — one per frontend app you
# run locally (web client + admin panel).
CORS_ORIGIN=http://localhost,http://localhost:5173,http://localhost:5174

# ------------------------------------------------------------------------------
# Public URLs — used to build links inside transactional emails
# ------------------------------------------------------------------------------

# Base URL for links in player-facing emails (verification, password reset).
APP_URL=http://localhost:5173

# Base URL for links in admin emails (login OTP codes, staff invites).
ADMIN_URL=http://localhost:5174

# ------------------------------------------------------------------------------
# Payment gateway — Asaas (PIX) — optional locally
# ------------------------------------------------------------------------------

# API key from your Asaas sandbox account. Leave empty to disable
# deposits/withdrawals locally.
ASAAS_API_KEY=

# Shared secret validated on incoming Asaas webhook calls.
ASAAS_WEBHOOK_TOKEN=

# Options: sandbox | production — always use "sandbox" locally.
ASAAS_ENV=sandbox

# ------------------------------------------------------------------------------
# AI — DeepSeek API — optional locally
# ------------------------------------------------------------------------------

# API key from https://platform.deepseek.com. Leave empty to disable all
# AI-assisted features (anti-cheat, admin chatbot, ticket summaries).
DEEPSEEK_API_KEY=

# ------------------------------------------------------------------------------
# Transactional email (SMTP) — required to exercise signup/password-reset
# flows locally, since the API throws on startup without it
# ------------------------------------------------------------------------------

# REQUIRED. SMTP server hostname.
# Examples: smtp.hostinger.com, smtp.gmail.com, sandbox.smtp.mailtrap.io
SMTP_HOST=

# SMTP server port. Common values: 465 (implicit SSL) or 587 (STARTTLS).
SMTP_PORT=465

# REQUIRED. SMTP account username.
SMTP_USER=

# REQUIRED. SMTP account password (or app-specific password).
SMTP_PASS=

# "From" header on outgoing emails.
# Format: "Display Name <email@yourdomain.com>"
SMTP_FROM=

# ------------------------------------------------------------------------------
# Chess engine (offline vs-AI opponent)
# ------------------------------------------------------------------------------

# Path to a Stockfish binary on the machine/container running the API.
# Defaults to /usr/bin/stockfish if omitted.
STOCKFISH_PATH=/usr/bin/stockfish

# ------------------------------------------------------------------------------
# One-off admin bootstrap scripts
# (apps/api/scripts/seed-admin.js and apps/api/scripts/reset-db.js)
#
# Only read when running those scripts directly — the API server itself
# ignores these.
# ------------------------------------------------------------------------------

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Admin
