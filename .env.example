# ==============================================================================
# Mega Chess Online — Production environment variables
#
# Used by: docker-compose.prod.yml
#
# Copy this file to `.env` in the project root, fill in every value below,
# then run:
#   docker compose -f docker-compose.prod.yml up -d --build
#
# Docker Compose automatically loads a file literally named `.env` from the
# project root — no extra flag needed. Every variable below that has no
# default is REQUIRED: the stack will refuse to start (with a clear error
# naming the missing variable) until it is set.
# ==============================================================================

# ------------------------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------------------------

# Database name created inside the Postgres container.
POSTGRES_DB=megachess

# Database user created inside the Postgres container.
POSTGRES_USER=chess

# REQUIRED. Database password — use a long, random string.
# Generate one with: openssl rand -base64 32
POSTGRES_PASSWORD=

# ------------------------------------------------------------------------------
# Authentication (JWT secrets)
# ------------------------------------------------------------------------------

# REQUIRED. Secret used to sign player access/refresh sessions.
# Generate with: openssl rand -hex 64
JWT_SECRET=

# REQUIRED. Secret reserved for refresh-token signing — use a different
# random value than JWT_SECRET.
JWT_REFRESH_SECRET=

# REQUIRED. Secret used to sign admin-panel JWTs — use a different random
# value than the two above.
ADMIN_JWT_SECRET=

# ------------------------------------------------------------------------------
# Public URLs — drive CORS, the frontend builds, Traefik routing, and every
# link sent in transactional emails. No static/hardcoded domain is used
# anywhere else in the stack; everything is derived from these values.
# ------------------------------------------------------------------------------

# REQUIRED. Full public URL of the player-facing web app, protocol included.
# Example: https://myapp.example.com
APP_URL=

# REQUIRED. Full public URL of the admin panel, protocol included.
# Example: https://admin.myapp.example.com
ADMIN_URL=

# REQUIRED. Bare hostname (no protocol, no trailing slash) of the admin
# panel — must match the host portion of ADMIN_URL above. Compose label
# interpolation can't strip the protocol from a URL, so it needs its own
# variable. Example: admin.myapp.example.com
ADMIN_DOMAIN=

# Internal Docker network address of the API service (host:port). Only
# change this if you rename the `api` service in docker-compose.prod.yml.
API_UPSTREAM=api:3000

# ------------------------------------------------------------------------------
# Payment gateway — Asaas (PIX deposits & withdrawals)
# ------------------------------------------------------------------------------

# API key from your Asaas account: Settings -> Integrations -> API Key.
# Leave empty to disable deposits/withdrawals entirely.
ASAAS_API_KEY=

# Shared secret you configure on the Asaas webhook (Settings -> Webhooks).
# The API validates every incoming webhook call against this value via the
# `asaas-access-token` header.
ASAAS_WEBHOOK_TOKEN=

# Which Asaas environment to call.
# Options: sandbox | production
ASAAS_ENV=sandbox

# ------------------------------------------------------------------------------
# AI — DeepSeek API (anti-cheat risk analysis, admin chatbot, ticket summaries)
# ------------------------------------------------------------------------------

# API key from https://platform.deepseek.com.
# Leave empty to disable all AI-assisted features.
DEEPSEEK_API_KEY=

# ------------------------------------------------------------------------------
# Transactional email (SMTP) — used for signup verification, password reset,
# admin OTP codes, etc.
# ------------------------------------------------------------------------------

# REQUIRED. SMTP server hostname.
# Examples: smtp.hostinger.com, smtp.gmail.com, smtp.sendgrid.net
SMTP_HOST=

# SMTP server port. Common values: 465 (implicit SSL) or 587 (STARTTLS).
SMTP_PORT=465

# REQUIRED. SMTP account username (usually the sending email address).
SMTP_USER=

# REQUIRED. SMTP account password (or an app-specific password, e.g. Gmail
# App Passwords).
SMTP_PASS=

# "From" header on outgoing emails.
# Format: "Display Name <email@yourdomain.com>"
SMTP_FROM=
